{
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ng serve",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "npm: start",
            "url": "${input:blocUiAppUrl}"
        },
        {
            "name": "ng test",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "npm: test",
            "url": "${input:blocUiTestUrl}"
        }
    ],
    "inputs": [
        {
            "id": "blocUiAppUrl",
            "type": "promptString",
            "description": "App URL (for ng serve debug launch)",
            "default": "http://dev.localhost:4200/"
        },
        {
            "id": "blocUiTestUrl",
            "type": "promptString",
            "description": "Karma debug URL (for ng test debug launch)",
            "default": "http://dev.localhost:9876/debug.html"
        }
    ]
}
